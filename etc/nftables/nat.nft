flush ruleset

table ip nat {
        chain postrouting {
                type nat hook postrouting priority srcnat; policy accept;
                iifname "virbr0" oifname "eth0" masquerade
        }
}
table ip6 nat {
        chain postrouting {
                type nat hook postrouting priority srcnat; policy accept;
                oifname "eth0" ip6 saddr 2001:db8::/32 masquerade
        }
}
